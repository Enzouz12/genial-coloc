# Configuration Supabase pour le stockage partagé en temps réel.
# Copier ce fichier en .env et renseigner les valeurs du projet Supabase
# (Project Settings > API). La clé anon est publique par conception.
# Sans ces variables, l'app utilise le stockage local du navigateur.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
